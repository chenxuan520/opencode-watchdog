{
  "name": "opencode-watchdog",
  "version": "0.1.2",
  "description": "Toggle-based watchdog judge plugin for the OpenCode TUI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenxuan520/opencode-watchdog.git"
  },
  "homepage": "https://github.com/chenxuan520/opencode-watchdog#readme",
  "bugs": {
    "url": "https://github.com/chenxuan520/opencode-watchdog/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "watchdog",
    "auto-continue",
    "tui"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "config": {
        "judgeAgent": "watchdog-judge"
      }
    },
    "./tui": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "config": {
        "commandKeybind": "ctrl+q",
        "judgeAgent": "watchdog-judge",
        "threshold": 70,
        "settleMs": 1200,
        "maxContinues": 8
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "typescript": "^5.8.2"
  }
}
